# Environment Configuration
NODE_ENV=development
PORT=5000

# Database
MONGODB_URI=mongodb://localhost:27017/campusfind
# For MongoDB Atlas, use:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/campusfind?retryWrites=true&w=majority

# JWT Secret (generate a random string for production)
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRE=24h

# Email Configuration (using Gmail)
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@rvce.edu.in
EMAIL_PASSWORD=your_app_password_here
EMAIL_FROM=CampusFind <noreply@rvce.edu.in>

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# File Upload
MAX_FILE_SIZE=5242880
# 5MB in bytes

# Admin Configuration
# Admin Configuration
# Use JSON format for multiple admins:
ADMIN_ACCOUNTS='[{"email":"admin@rvce.edu.in","password":"StrongPassword123!"}]'
